---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteForm from '../components/SiteForm.astro';
---

<BaseLayout
  title="Level303 — Sementara Offline"
  description="Situs Level303 sementara offline. Tinggalkan pesan untuk menerima kabar saat situs aktif kembali."
  ogTitle="Level303 — Sementara Offline"
  ogDescription="Situs Level303 sementara offline. Tinggalkan pesan untuk menerima kabar saat situs aktif kembali."
>
  <main class="placeholder-page">
    <section class="placeholder-card" aria-labelledby="heroHeading">
      <h1 id="heroHeading">Level303 — Kami Sedang Memulihkan Situs</h1>
      <p>
        Situs kami sementara offline. Kami sedang bekerja untuk mengembalikan akses secepat mungkin.
        Tinggalkan pesan dan kami akan beri kabar ketika situs aktif lagi.
      </p>

      <SiteForm formId="contact" />

      <p class="secondary-cta">Butuh bantuan segera? Balas email ini untuk berkomunikasi.</p>
    </section>

    <footer class="placeholder-footer">
      <p>Temporary placeholder provided by Pluzi.</p>
    </footer>
  </main>

  <style>
    :global(body) {
      margin: 0;
      background: #fff;
      color: #000;
      font-family: Arial, sans-serif;
      line-height: 1.5;
    }

    .placeholder-page {
      min-height: 100vh;
      padding: 48px 16px 24px;
    }

    .placeholder-card {
      max-width: 640px;
      margin: 0 auto;
    }

    h1 {
      font-size: clamp(1.75rem, 4.5vw, 2.25rem);
      line-height: 1.2;
      margin: 0 0 16px;
      color: #000;
    }

    p {
      margin: 0 0 24px;
      color: #000;
    }

    :global(.placeholder-form .form-group) {
      margin-bottom: 16px;
    }

    :global(.placeholder-form label) {
      display: block;
      margin-bottom: 8px;
      font-size: 0.95rem;
      color: #000;
    }

    :global(.placeholder-form input),
    :global(.placeholder-form textarea) {
      width: 100%;
      border: 1px solid #000;
      border-radius: 0;
      padding: 10px 12px;
      font: inherit;
      color: #000;
      background: #fff;
    }

    :global(.placeholder-form textarea) {
      resize: vertical;
      min-height: 120px;
    }

    :global(.placeholder-form .submit-btn) {
      display: inline-block;
      border: 1px solid #000;
      border-radius: 0;
      background: #000;
      color: #fff;
      padding: 12px 24px;
      min-height: 44px;
      min-width: 96px;
      font: inherit;
      font-weight: 600;
      cursor: pointer;
    }

    :global(.placeholder-form .submit-btn:hover) {
      background: #111;
    }

    :global(.placeholder-form .submit-btn:focus-visible) {
      outline: 2px solid #000;
      outline-offset: 2px;
    }

    :global(.placeholder-form .submit-btn:disabled) {
      opacity: 0.6;
      cursor: not-allowed;
    }

    :global(.error-message) {
      display: block;
      margin-top: 6px;
      min-height: 1.2em;
      font-size: 0.875rem;
      color: #b00020;
    }

    :global(#responseMessage) {
      margin-top: 16px;
      color: #b00020;
      font-size: 0.9rem;
    }

    .secondary-cta {
      margin-top: 24px;
      margin-bottom: 0;
      font-size: 0.875rem;
    }

    .placeholder-footer {
      max-width: 640px;
      margin: 40px auto 0;
      padding-top: 16px;
      border-top: 1px solid #ddd;
    }

    .placeholder-footer p {
      margin: 0;
      font-size: 0.8rem;
      color: #333;
    }

    @media (max-width: 600px) {
      .placeholder-page {
        padding-top: 32px;
      }
    }
  </style>
</BaseLayout>
